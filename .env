# ==========================================
# LLM Provider 配置模板
# ==========================================
#
# 使用说明：
# 1. 设置 OPENCLAW_MINI_PROVIDER 为你选择的提供商
# 2. 配置对应的 API Key 和模型
# 3. 可选配置：base_url, temperature 等
#
# ==========================================

# ==========================================
# 选择你的 LLM 提供商
# 可选值: openai | deepseek | anthropic | google | groq | zhipu | mistral | lmstudio | ollama | openrouter
# ==========================================
OPENCLAW_MINI_PROVIDER=deepseek

# ==========================================
# Model 配置 (需与 Provider 匹配)
# ==========================================
OPENCLAW_MINI_MODEL=deepseek-chat

# ==========================================
# API Base URL 配置
# (代理、自部署端点、Azure OpenAI 等)
# ==========================================
OPENCLAW_MINI_BASE_URL=https://api.deepseek.com

# ==========================================
# 各 Provider API Key 配置
# ==========================================
API_KEY=sk-55bba0e340b64aea92eeea54fa897560


# ==========================================
# Agent ID 配置 (可选，默认 main)
# ==========================================
OPENCLAW_MINI_AGENT_ID=main

# ==========================================
# 完整配置示例（取消注释并修改使用）
# ==========================================

# --- stateless_llm_with_template ---
# OPENCLAW_MINI_PROVIDER=stateless_llm_with_template
# OPENCLAW_MINI_MODEL=qwen2.5:latest
# OPENCLAW_MINI_BASE_URL=http://localhost:8080/v1
# 变量名: STATELESS_LLM_WITH_TEMPLATE_API_KEY

# --- openai_compatible_llm ---
# OPENCLAW_MINI_PROVIDER=openai_compatible_llm
# OPENCLAW_MINI_MODEL=qwen2.5:latest
# OPENCLAW_MINI_BASE_URL=http://localhost:11434/v1

# --- ollama_llm ---
# OPENCLAW_MINI_PROVIDER=ollama_llm
# OPENCLAW_MINI_MODEL=qwen2.5:latest
# OPENCLAW_MINI_BASE_URL=http://localhost:11434/v1
# 变量名: OLLAMA_LLM_API_KEY

# --- lmstudio_llm ---
# OPENCLAW_MINI_PROVIDER=lmstudio_llm
# OPENCLAW_MINI_MODEL=qwen2.5:latest
# OPENCLAW_MINI_BASE_URL=http://localhost:1234/v1
# 变量名: LMSTUDIO_LLM_API_KEY

